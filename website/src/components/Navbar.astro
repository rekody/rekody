---
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md" style="background:rgba(6,13,26,0.85); border-bottom:1px solid rgba(14,165,233,0.08);">
  <div class="max-w-5xl mx-auto px-5 h-16 flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group">
      <div class="relative">
        <img
          src="/icon.png"
          alt="chamgei"
          class="w-7 h-7 rounded-lg transition-all duration-300 group-hover:scale-105"
          style="box-shadow:0 0 14px rgba(14,165,233,0.35);"
        />
      </div>
      <span class="text-base font-semibold uppercase tracking-widest" style="color:#ffffff; letter-spacing:0.08em;">chamgei</span>
    </a>

    <!-- Center nav links (desktop only) -->
    <div class="hidden md:flex items-center gap-1 flex-1 justify-center">
      {[
        { label: "How it works", href: "#how-it-works" },
        { label: "Features",     href: "#features" },
        { label: "Install",      href: "#install" },
      ].map(link => (
        <a
          href={link.href}
          class="nav-link px-3 py-1.5 rounded-lg text-sm transition-all duration-150 hover:text-white"
          style="color:#6b7fa0;"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Right side (desktop) -->
    <div class="hidden md:flex items-center gap-2.5 shrink-0">
      <a
        href="https://github.com/tonykipkemboi/chamgei"
        target="_blank"
        rel="noopener noreferrer"
        class="github-pill flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm transition-all duration-150 hover:text-white"
        style="color:#8ba0bf; border:1px solid rgba(42,64,96,0.6); background:rgba(17,30,53,0.5);"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span>Star</span>
        <span class="text-xs font-mono px-1.5 py-0.5 rounded" style="background:rgba(14,165,233,0.12); color:#0ea5e9;">v0.3.0</span>
      </a>

      <a
        href="#install"
        class="btn-shimmer flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg text-sm font-medium text-white transition-opacity hover:opacity-90"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download
      </a>
    </div>

    <!-- Mobile right: download + hamburger -->
    <div class="flex md:hidden items-center gap-2 shrink-0">
      <a
        href="#install"
        class="btn-shimmer flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium text-white"
      >
        Download
      </a>
      <button
        id="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex items-center justify-center w-9 h-9 rounded-lg transition-colors"
        style="color:#6b7fa0; border:1px solid rgba(42,64,96,0.5);"
      >
        <svg id="hamburger-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="close-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    id="nav-drawer"
    class="hidden md:hidden"
    style="border-top:1px solid rgba(14,165,233,0.08); background:rgba(6,13,26,0.97);"
  >
    <div class="max-w-5xl mx-auto px-5 py-3 flex flex-col gap-1">
      {[
        { label: "How it works", href: "#how-it-works" },
        { label: "Features",     href: "#features" },
        { label: "Install",      href: "#install" },
      ].map(link => (
        <a
          href={link.href}
          class="drawer-link px-3 py-3 rounded-lg text-sm font-medium transition-colors hover:text-white"
          style="color:#8ba0bf;"
        >
          {link.label}
        </a>
      ))}
      <div class="my-1" style="height:1px; background:rgba(42,64,96,0.4);"></div>
      <a
        href="https://github.com/tonykipkemboi/chamgei"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-3 py-3 rounded-lg text-sm transition-colors hover:text-white"
        style="color:#8ba0bf;"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub <span class="ml-auto font-mono text-xs px-1.5 py-0.5 rounded" style="background:rgba(14,165,233,0.12); color:#0ea5e9;">v0.3.0</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle   = document.getElementById('nav-toggle');
  const drawer   = document.getElementById('nav-drawer');
  const hamIcon  = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function openDrawer() {
    drawer?.classList.remove('hidden');
    hamIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
  }
  function closeDrawer() {
    drawer?.classList.add('hidden');
    hamIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    drawer?.classList.contains('hidden') ? openDrawer() : closeDrawer();
  });

  // Close on any drawer link click
  drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeDrawer));

  // Close on outside click
  document.addEventListener('click', (e) => {
    const navbar = document.getElementById('navbar');
    if (navbar && !navbar.contains(e.target as Node)) closeDrawer();
  });
</script>
