---
const engines = [
  {
    name: 'Deepgram',
    tag: 'Default',
    model: 'Nova-3',
    latency: '~200ms',
    note: 'Cloud · 100+ languages · smart_format',
    highlight: true,
  },
  {
    name: 'Groq',
    tag: 'Cloud',
    model: 'Whisper large-v3',
    latency: '~250ms',
    note: 'Whisper large-v3, hosted. Faster than you expect.',
    highlight: false,
  },
  {
    name: 'whisper.cpp',
    tag: 'Local',
    model: 'ggml · CoreML',
    latency: 'Offline',
    note: 'Runs fully on-device. No network.',
    highlight: false,
  },
  {
    name: 'Self-hosted',
    tag: 'Custom',
    model: 'Any OpenAI-compatible STT',
    latency: 'Your SLA',
    note: 'Point at your own URL + API key.',
    highlight: false,
  },
];

const llmProviders = [
  { id: 'groq',      name: 'Groq' },
  { id: 'openai',    name: 'OpenAI' },
  { id: 'anthropic', name: 'Anthropic' },
  { id: 'gemini',    name: 'Gemini' },
  { id: 'ollama',    name: 'Ollama' },
  { id: 'cohere',    name: 'Cohere' },
  { id: 'mistral',   name: 'Mistral' },
  { id: 'cerebras',  name: 'Cerebras' },
];
---

<section id="engines" class="relative" style="background:var(--color-ink); color:var(--color-cream);">
  <div class="max-w-6xl mx-auto px-6 py-20">

    <!-- Heading -->
    <div class="mb-16 max-w-2xl">
      <p class="text-[11px] font-mono uppercase mb-4" style="color:rgba(251,250,244,0.5); letter-spacing:0.12em;">Engines</p>
      <h2 class="display" style="font-size:clamp(36px, 5vw, 56px); color:var(--color-cream);">
        Pick the engine <span class="display-italic" style="color:var(--color-teal);">—</span> swap anytime.
      </h2>
      <p class="body-serif mt-5" style="font-size:18px; color:rgba(251,250,244,0.7);">
        Four speech-to-text backends. Swap in settings. Cloud by default, fully local when the room demands it.
      </p>
    </div>

    <!-- Engine grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {engines.map(e => (
        <div
          class="rounded-2xl p-6 flex flex-col gap-4"
          style={`background:${e.highlight ? 'rgba(32,128,141,0.14)' : 'rgba(251,250,244,0.03)'}; border:1px solid ${e.highlight ? 'rgba(32,128,141,0.4)' : 'rgba(251,250,244,0.08)'};`}
        >
          <div class="flex items-center justify-between">
            <span class="display" style="font-size:22px; color:var(--color-cream);">{e.name}</span>
            <span class="text-[10px] font-mono uppercase px-2 py-0.5 rounded" style={`background:${e.highlight ? 'var(--color-teal)' : 'rgba(251,250,244,0.08)'}; color:${e.highlight ? 'var(--color-cream)' : 'rgba(251,250,244,0.6)'}; letter-spacing:0.08em;`}>{e.tag}</span>
          </div>
          <div>
            <div class="text-[13px] font-mono" style="color:rgba(251,250,244,0.9);">{e.model}</div>
            <div class="text-[12px] font-mono mt-1" style="color:var(--color-teal);">{e.latency}</div>
          </div>
          <p class="text-[13px] body-serif" style="color:rgba(251,250,244,0.6); line-height:1.5;">{e.note}</p>
        </div>
      ))}
    </div>

    <!-- LLM polish row -->
    <div class="rounded-2xl overflow-hidden" style="background:rgba(251,250,244,0.03); border:1px solid rgba(251,250,244,0.08);">
      <div class="p-6 sm:p-8 max-w-2xl">
        <p class="text-[11px] font-mono uppercase mb-2" style="color:rgba(251,250,244,0.5); letter-spacing:0.12em;">Optional LLM polish</p>
        <h3 class="display" style="font-size:24px; color:var(--color-cream);">Post-process your transcripts.</h3>
        <p class="body-serif mt-2" style="font-size:14px; color:rgba(251,250,244,0.65);">Route transcripts through your model of choice to tighten grammar, translate, or reformat. Off by default — Deepgram's smart_format usually suffices.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-px" style="background:rgba(251,250,244,0.08); border-top:1px solid rgba(251,250,244,0.08);">
        {llmProviders.map(p => (
          <div
            class="flex items-center justify-center h-24"
            style="background:var(--color-ink); color:rgba(251,250,244,0.9);"
            aria-label={p.name}
            title={p.name}
          >
            {p.id === 'groq' && (
