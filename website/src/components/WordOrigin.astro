---
---

<section class="relative overflow-hidden shader-warm">
  <div class="grain"></div>

  <div class="relative max-w-6xl mx-auto px-6 py-20 grid lg:grid-cols-[1.3fr_1fr] gap-16 items-center">

    <!-- Giant italic word -->
    <div class="relative">
      <p class="text-[11px] font-mono uppercase mb-6" style="color:var(--color-ink-faint); letter-spacing:0.12em;">On the name</p>

      <h2 class="display-italic leading-[0.9]" style="font-size:clamp(96px, 14vw, 180px); color:var(--color-ink); letter-spacing:-0.04em;">
        rekody
      </h2>

      <!-- IPA + pronounce -->
      <div class="mt-6 flex items-center gap-4 flex-wrap">
        <span class="font-mono text-lg" style="color:var(--color-ink-mute);">/rɛˈkoʊ.di/</span>

        <button
          id="pronounce-btn"
          aria-label="Hear pronunciation"
          class="pill pill-ghost"
        >
          <svg id="play-icon" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg id="pause-icon" class="w-3.5 h-3.5 hidden" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
          </svg>
          <span>Pronounce</span>
        </button>

        <audio id="pronounce-audio" src="/audio/rekody.mp3" preload="none"></audio>
      </div>
    </div>

    <!-- Meaning card -->
    <div class="relative">
      <div class="rounded-2xl p-7" style="background:rgba(251,250,244,0.7); border:1px solid var(--color-hairline); backdrop-filter:blur(10px);">
        <div class="flex items-center gap-2 mb-5">
          <span class="text-[11px] font-mono uppercase" style="color:var(--color-teal); letter-spacing:0.12em;">Swahili · East Africa</span>
        </div>

        <p class="body-serif" style="font-size:18px; color:var(--color-ink); line-height:1.55;">
          From Swahili <em>rekodi</em> — <em>"to record."</em> Stylized to <em>rekody</em>. A record is what a voice leaves behind once the sound is gone; every time you hold <span class="key">⌥</span> <span class="key">Space</span>, speech becomes text — a small, faithful record of what you said.
        </p>

        <div class="hairline my-6"></div>

        <dl class="grid grid-cols-2 gap-4 text-[13px]">
          {[
            { label: 'Family',   value: 'Niger-Congo · Bantu' },
            { label: 'Region',   value: 'East Africa · Lingua franca' },
            { label: 'Speakers', value: '~200 million' },
            { label: 'Script',   value: 'Latin' },
          ].map(i => (
            <div>
              <dt class="font-mono uppercase text-[10px]" style="color:var(--color-ink-faint); letter-spacing:0.1em;">{i.label}</dt>
              <dd class="mt-1" style="color:var(--color-ink-soft);">{i.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>

<script>
  const btn       = document.getElementById('pronounce-btn');
  const audio     = document.getElementById('pronounce-audio') as HTMLAudioElement | null;
  const playIcon  = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');

  function setPlaying(playing: boolean) {
    playIcon?.classList.toggle('hidden', playing);
    pauseIcon?.classList.toggle('hidden', !playing);
  }

  btn?.addEventListener('click', () => {
    if (!audio) return;
    if (audio.paused) audio.play();
    else { audio.pause(); audio.currentTime = 0; }
  });
  audio?.addEventListener('play',  () => setPlaying(true));
  audio?.addEventListener('pause', () => setPlaying(false));
  audio?.addEventListener('ended', () => setPlaying(false));
</script>
